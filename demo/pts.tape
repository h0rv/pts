Output assets/demo.gif
Set Shell "bash"
Set FontFamily "Maple Mono Medium"
Set FontSize 14
Set LetterSpacing 0
Set LineHeight 1.1
Set Width 860
Set Height 560
Set Padding 12
Set Theme "Monokai Pro (Filter Ristretto)"

Type "./zig-out/bin/pts"
Enter
Sleep 1500ms
Down 6
Sleep 600ms
PageDown
Sleep 800ms
Up 2
Sleep 500ms
Enter
Sleep 1500ms
Type "b"
Sleep 700ms
Type "q"
